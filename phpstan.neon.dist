includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
    level: 6
    paths:
        - src
        - codeon-multilingual.php
        - uninstall.php
    excludePaths:
        - vendor
        - node_modules
        - tests
    bootstrapFiles:
        - tests/phpstan-stubs.php
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
    parallel:
        maximumNumberOfProcesses: 1
